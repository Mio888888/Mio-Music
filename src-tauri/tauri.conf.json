{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mio Music",
  "version": "0.2.0",
  "identifier": "com.vant.Mio.Music",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://tdesign.gtimg.com; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost imgproxy: http://imgproxy.localhost http: https: data:; media-src 'self' asset: http://asset.localhost http: https: data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdEQzM2NUNGNjI1RUY2MEQKUldRTjlsNWl6MlhEZlcrVDM0V2YzWWUxSTNXYXprbmNzdUZQK2xYY1hKWUhQZFdBOTZVR2w3eTMK",
      "endpoints": [
        "https://github.com/Mio888888/Mio-Music/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "infoPlist": "Info.plist",
      "entitlements": "Mio Music.entitlements"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
